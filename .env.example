# Copia este archivo a .env y llena con tus valores reales.
# NO subir .env a git.

DB_URL=jdbc:postgresql://HOST:5432/DBNAME?sslmode=require
DB_USER=usuario
DB_PASS=password

# Perfil de Spring (dev, local, prod)
SPRING_PROFILES_ACTIVE=prod

# Puerto de la aplicacion (opcional, default 8081)
SERVER_PORT=8081
